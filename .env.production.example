DJANGO_SETTINGS_MODULE=learnflow.settings.production
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=learnflow.cloud-ip.cc,api.learnflow.cloud-ip.cc,www.learnflow.cloud-ip.cc

FRONTEND_URL=https://learnflow.cloud-ip.cc
CORS_ALLOWED_ORIGINS=https://learnflow.cloud-ip.cc,https://www.learnflow.cloud-ip.cc

DATABASE_URL=postgres://learnflow:CHANGE_ME_STRONG_PASSWORD@db:5432/learnflow
POSTGRES_DB=learnflow
POSTGRES_USER=learnflow
POSTGRES_PASSWORD=

REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/2

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=learnflow-prod
AWS_S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto

JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@learnflow.cloud-ip.cc

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

CLICK_PROVIDER_TOKEN=

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

ENABLE_DEBUG_TOOLBAR=False
ENABLE_SILK_PROFILER=False

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
